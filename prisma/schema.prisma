generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// الحالات / المرضى
model Patient {
  id            String   @id @default(cuid())
  name          String
  phone         String?
  age           Int?
  gender        String   @default("male")
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  visits        Visit[]
  photos        PatientPhoto[]
  alerts        Alert[]

  // Laser relations
  laserProfile  LaserProfile?
  laserSessions LaserSession[]
  laserPackages LaserPackage[]
}

// أنواع الجلسات
model SessionType {
  id            String   @id @default(cuid())
  name          String
  price         Float    @default(0)
  description   String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  visits        Visit[]
}

// الزيارات / الجلسات
model Visit {
  id            String   @id @default(cuid())
  patientId     String
  sessionTypeId String?
  date          DateTime @default(now())
  price         Float    @default(0)
  paid          Float    @default(0)
  remaining     Float    @default(0)
  notes         String?
  status        String   @default("completed")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  sessionType   SessionType? @relation(fields: [sessionTypeId], references: [id], onDelete: SetNull)
  laserTreatments LaserTreatment[]
}

// ليزر إزالة الشعر (القديم - للتوافق)
model LaserTreatment {
  id            String   @id @default(cuid())
  visitId       String
  area          String
  skinType      String?
  hairColor     String?
  skinSensitivity String?
  fluence       String?
  pulseWidth    String?
  spotSize      String?
  coolingType   String?
  painLevel     Int?
  progress      String?
  sessionsDone  Int      @default(0)
  sessionsTotal Int      @default(0)
  nextSessionDate DateTime?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  visit         Visit    @relation(fields: [visitId], references: [id], onDelete: Cascade)
}

// صور قبل وبعد
model PatientPhoto {
  id            String   @id @default(cuid())
  patientId     String
  visitId       String?
  type          String   @default("before")
  photoUrl      String
  notes         String?
  createdAt     DateTime @default(now())

  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

// المصروفات
model Expense {
  id            String   @id @default(cuid())
  category      String
  amount        Float
  description   String?
  date          DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// الإيرادات
model Revenue {
  id            String   @id @default(cuid())
  category      String   @default("sessions")
  amount        Float
  description   String?
  date          DateTime @default(now())
  visitId       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// التنبيهات والإشعارات
model Alert {
  id            String   @id @default(cuid())
  patientId     String?
  title         String
  message       String
  type          String   @default("reminder")
  date          DateTime @default(now())
  isRead        Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  patient       Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)
}

// نسخ احتياطية
model Backup {
  id            String   @id @default(cuid())
  name          String
  data          String
  size          Int      @default(0)
  createdAt     DateTime @default(now())
}

// ═══════════════════════════════════════
// ═══ نظام الليزر المتكامل ═════════════
// ═══════════════════════════════════════

// أجهزة الليزر
model LaserMachine {
  id            String   @id @default(cuid())
  name          String   // مثل: Candela GentleLase Pro, Soprano Titanium
  type          String   // نوع الشعاع: Alexandrite, Diode, Nd:YAG, IPL, Ruby
  wavelength    String?  // الطول الموجي: 755nm, 810nm, 1064nm
  maxFluence    Float?   // أقصى طاقة J/cm²
  spotSizes     String?  // أحجام البقعة المتاحة (مثلا: 10,12,15,18 mm)
  isActive      Boolean  @default(true)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions      LaserSession[]
}

// مناطق العلاج
model LaserArea {
  id            String   @id @default(cuid())
  name          String   // مثل: الوجه الكامل, الشارب, البطن, الساقين
  malePulses    Int      @default(200)   // متوسط النبضات للذكور
  femalePulses  Int      @default(150)   // متوسط النبضات للإناث
  pulsePrice    Float    @default(0)     // سعر النبضة الواحدة (ج.م)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions      LaserSession[]
  packages      LaserPackage[]
}

// بروفايل المريض لليزر
model LaserProfile {
  id                String   @id @default(cuid())
  patientId         String   @unique
  skinType          String   // Fitzpatrick: 1-6
  hairColor         String?  // أسود, بني غامق, بني فاتح, أشقر, أحمر, رمادي
  hairThickness     String?  // thin, medium, thick
  skinSensitivity  String?  // low, medium, high
  hormonalConditions String? // حالات هرمونية
  contraindications String? // موانع استعمال
  previousTreatments String? // علاجات سابقة
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  patient           Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  sessions          LaserSession[]
  packages          LaserPackage[]
}

// جلسات الليزر
model LaserSession {
  id              String   @id @default(cuid())
  profileId       String
  patientId       String
  machineId       String
  areaId          String
  packageId       String?  // إذا كانت الجلسة من باقة

  sessionNumber   Int      @default(1)
  date            DateTime @default(now())

  // إعدادات الجهاز
  fluence         Float    // الطاقة J/cm²
  pulseWidth      Float    // عرض النبضة ms
  spotSize        Float    // حجم البقعة mm
  cooling         String?  // نوع التبريد: contact, spray, cryo, none

  // النبضات
  pulsesUsed      Int      @default(0)
  pulsesPerSecond Int?

  // المحاسبة - نظام النبضات
  paymentMode     String   @default("pulse") // "pulse" أو "package"
  pulsePrice      Float    @default(0)       // سعر النبضة
  totalAmount     Float    @default(0)       // الإجمالي = نبضات × سعر النبضة
  paid            Float    @default(0)       // المدفوع
  remaining       Float    @default(0)       // المتبقي

  // التقدم
  painLevel       Int?
  hairReduction   Float?   // نسبة تقليل الشعر %
  sideEffects     String?  // آثار جانبية
  skinReaction    String?  // رد فعل الجلد
  notes           String?
  status          String   @default("completed") // completed, scheduled, cancelled
  nextSessionDate DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  profile         LaserProfile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  patient         Patient       @relation(fields: [patientId], references: [id])
  machine         LaserMachine  @relation(fields: [machineId], references: [id])
  area            LaserArea     @relation(fields: [areaId], references: [id])
  package         LaserPackage? @relation(fields: [packageId], references: [id])
}

// باقات الليزر
model LaserPackage {
  id                String   @id @default(cuid())
  profileId         String
  patientId         String
  areaId            String

  name              String   // مثل: باقة 6 جلسات - ساقين
  totalSessions     Int
  totalPulses       Int      @default(0)
  usedSessions      Int      @default(0)
  usedPulses        Int      @default(0)
  remainingSessions Int
  remainingPulses   Int      @default(0)
  totalPrice        Float
  paid              Float    @default(0)
  remaining         Float    @default(0)
  status            String   @default("active") // active, completed, expired
  purchaseDate      DateTime @default(now())
  expiryDate        DateTime?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  profile           LaserProfile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  patient           Patient       @relation(fields: [patientId], references: [id])
  area              LaserArea     @relation(fields: [areaId], references: [id])
  sessions          LaserSession[]
}

// إيرادات الليزر
model LaserRevenue {
  id              String   @id @default(cuid())
  patientId       String?
  sessionId       String?
  packageId       String?
  type            String   @default("session") // session, package, extra
  amount          Float
  description     String?
  date            DateTime @default(now())
  createdAt       DateTime @default(now())
}
